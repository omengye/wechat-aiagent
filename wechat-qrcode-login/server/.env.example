# Upstream OAuth server base URL (no trailing slash)
OAUTH_BASE_URL=https://oauth.example.com

# OAuth client credentials (server-side only)
OAUTH_CLIENT_ID=app_myapp_client
OAUTH_CLIENT_SECRET=replace_with_real_secret

# OAuth redirect URL (must match your OAuth app config)
OAUTH_REDIRECT_URL=http://localhost:5173/#/oauth/callback

# Optional: override token path if your upstream differs
OAUTH_TOKEN_PATH=/api/oauth/token

# Allowed browser origin for CORS
CORS_ORIGIN=http://localhost:5173
