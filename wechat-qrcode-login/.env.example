# ==================== API Configuration ====================
# API base URL for OAuth requests
# 开发环境：留空使用 Vite 代理（推荐）
# 生产环境：设置完整 URL，如 https://your-api.com
VITE_API_BASE_URL=

# API Origin header (用于 CORS 请求)
# 开发环境：http://localhost:5173
# 生产环境：https://your-domain.com（与前端部署地址一致）
VITE_API_ORIGIN=http://localhost:5173

# ==================== WebSocket Configuration ====================
# WebSocket Host
# 开发环境：使用 localhost:5173 通过 Vite 代理
# 生产环境：使用实际的 WebSocket 服务器地址
VITE_WS_HOST=localhost:5173

# WebSocket Path (default: /api/ws)
VITE_WS_PATH=/api/ws

# WebSocket timeout in milliseconds (default: 300000 = 5 minutes)
VITE_WS_TIMEOUT=300000

# WebSocket URL for CSP connect-src (用于 Content Security Policy)
# 开发环境：ws://localhost:5173（通过 Vite 代理）
# 生产环境：wss://your-domain.com（实际 WebSocket 服务器）
VITE_WS_CSP_URL=ws://localhost:5173

# ==================== OAuth Configuration ====================
# OAuth Client ID (from backend config.yaml oauthClients)
VITE_OAUTH_CLIENT_ID=app_myapp_client

# OAuth Authorize Base URL (upstream OAuth server, used for /api/oauth/authorize)
VITE_OAUTH_AUTHORIZE_BASE_URL=

# ⚠️ WARNING: Storing client secrets in frontend code is a security risk!
# OAuth Redirect URL (your application callback URL)
# 注意：使用 hash 路由，需要包含 #
VITE_OAUTH_REDIRECT_URL=http://localhost:5173/#/oauth/callback

# OAuth Scopes (space-separated)
VITE_OAUTH_SCOPE=user:read offline_access

# OAuth Response Type (usually 'code' for authorization code flow)
VITE_OAUTH_RESPONSE_TYPE=code

# ==================== WeChat Configuration ====================
# WeChat Login Project ID (用于普通登录页面 /login)
# 从 backend config.yaml qrcode[0].projectId 获取
VITE_LOGIN_PROJECT_ID=b2922f3174caf3965bd03a30688fc398

# WeChat OAuth Project ID (用于 OAuth 授权页面 /oauth/authorize)
# 从 backend config.yaml qrcode[1].projectId 获取（包含 oauthClients 的项目）
VITE_OAUTH_PROJECT_ID=3333333334caf3965bd03a30688fc398
